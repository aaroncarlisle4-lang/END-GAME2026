{
  "manifest_version": 3,
  "name": "NotebookLM Cookie Exporter",
  "version": "1.0",
  "description": "One-click export of all Google/NotebookLM cookies for CLI auth",
  "permissions": ["cookies", "clipboardWrite"],
  "host_permissions": [
    "*://*.google.com/*",
    "*://notebooklm.google.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png"
  }
}
